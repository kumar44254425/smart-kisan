<web-app xmlns="http://xmlns.jcp.org/xml/ns/javaee"
         xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
         xsi:schemaLocation="http://xmlns.jcp.org/xml/ns/javaee
                             http://xmlns.jcp.org/xml/ns/javaee/web-app_3_1.xsd"
         version="3.1">

    <!-- Signup -->
    <servlet>
        <servlet-name>SignupServlet</servlet-name>
        <servlet-class>com.smartkisan.servlets.SignupServlet</servlet-class>
    </servlet>
    <servlet-mapping>
        <servlet-name>SignupServlet</servlet-name>
        <url-pattern>/signup</url-pattern>
    </servlet-mapping>

    <!-- Login -->
    <servlet>
        <servlet-name>LoginServlet</servlet-name>
        <servlet-class>com.smartkisan.servlets.LoginServlet</servlet-class>
    </servlet>
    <servlet-mapping>
        <servlet-name>LoginServlet</servlet-name>
        <url-pattern>/login</url-pattern>
    </servlet-mapping>

    <!-- OTP Request -->
    <servlet>
        <servlet-name>RequestOtpServlet</servlet-name>
        <servlet-class>com.smartkisan.servlets.RequestOtpServlet</servlet-class>
    </servlet>
    <servlet-mapping>
        <servlet-name>RequestOtpServlet</servlet-name>
        <url-pattern>/request-otp</url-pattern>
    </servlet-mapping>

    <!-- OTP Verify -->
    <servlet>
        <servlet-name>VerifyOtpServlet</servlet-name>
        <servlet-class>com.smartkisan.servlets.VerifyOtpServlet</servlet-class>
    </servlet>
    <servlet-mapping>
        <servlet-name>VerifyOtpServlet</servlet-name>
        <url-pattern>/verify-otp</url-pattern>
    </servlet-mapping>

    <!-- Set Password -->
    <servlet>
        <servlet-name>SetPasswordServlet</servlet-name>
        <servlet-class>com.smartkisan.servlets.SetPasswordServlet</servlet-class>
    </servlet>
    <servlet-mapping>
        <servlet-name>SetPasswordServlet</servlet-name>
        <url-pattern>/set-password</url-pattern>
    </servlet-mapping>

    <!-- Reset Password -->
    <servlet>
        <servlet-name>ResetPasswordServlet</servlet-name>
        <servlet-class>com.smartkisan.servlets.ResetPasswordServlet</servlet-class>
    </servlet>
    <servlet-mapping>
        <servlet-name>ResetPasswordServlet</servlet-name>
        <url-pattern>/reset-password</url-pattern>
    </servlet-mapping>

    <!-- Logout -->
    <servlet>
        <servlet-name>LogoutServlet</servlet-name>
        <servlet-class>com.smartkisan.servlets.LogoutServlet</servlet-class>
    </servlet>
    <servlet-mapping>
        <servlet-name>LogoutServlet</servlet-name>
        <url-pattern>/logout</url-pattern>
    </servlet-mapping>

    <!-- Prices -->
    <servlet>
        <servlet-name>PriceServlet</servlet-name>
        <servlet-class>com.smartkisan.servlets.PriceServlet</servlet-class>
    </servlet>
    <servlet-mapping>
        <servlet-name>PriceServlet</servlet-name>
        <url-pattern>/prices</url-pattern>
    </servlet-mapping>

    <!-- Admin Add Daily Price -->
    <servlet>
        <servlet-name>AdminAddPriceServlet</servlet-name>
        <servlet-class>com.smartkisan.servlets.AdminAddPriceServlet</servlet-class>
    </servlet>
    <servlet-mapping>
        <servlet-name>AdminAddPriceServlet</servlet-name>
        <url-pattern>/admin/add-price</url-pattern>
    </servlet-mapping>

    <!-- Fetch Live Market Prices -->
    <servlet>
        <servlet-name>LivePriceFetcherServlet</servlet-name>
        <servlet-class>com.smartkisan.servlets.LivePriceFetcherServlet</servlet-class>
    </servlet>
    <servlet-mapping>
        <servlet-name>LivePriceFetcherServlet</servlet-name>
        <url-pattern>/admin/fetch-live-prices</url-pattern>
    </servlet-mapping>

    <!-- Products -->
    <servlet>
        <servlet-name>ProductServlet</servlet-name>
        <servlet-class>com.smartkisan.servlets.ProductServlet</servlet-class>
    </servlet>
    <servlet-mapping>
        <servlet-name>ProductServlet</servlet-name>
        <url-pattern>/products</url-pattern>
    </servlet-mapping>

    <!-- Place Order -->
    <servlet>
        <servlet-name>OrderServlet</servlet-name>
        <servlet-class>com.smartkisan.servlets.OrderServlet</servlet-class>
    </servlet>
    <servlet-mapping>
        <servlet-name>OrderServlet</servlet-name>
        <url-pattern>/order</url-pattern>
    </servlet-mapping>

    <!-- List Orders -->
    <servlet>
        <servlet-name>OrdersListServlet</servlet-name>
        <servlet-class>com.smartkisan.servlets.OrdersListServlet</servlet-class>
    </servlet>
    <servlet-mapping>
        <servlet-name>OrdersListServlet</servlet-name>
        <url-pattern>/orders</url-pattern>
    </servlet-mapping>
<!-- Crop Profit Calculator -->
<servlet>
    <servlet-name>CropProfitServlet</servlet-name>
    <servlet-class>com.smartkisan.servlets.CropProfitServlet</servlet-class>
</servlet>
<servlet-mapping>
    <servlet-name>CropProfitServlet</servlet-name>
    <url-pattern>/profit</url-pattern>
</servlet-mapping>
   <servlet>

    <servlet-name>AllIndiaWeatherServlet</servlet-name>
    <servlet-class>com.smartkisan.servlets.AllIndiaWeatherServlet</servlet-class>
</servlet>

<servlet-mapping>
    <servlet-name>AllIndiaWeatherServlet</servlet-name>
    <url-pattern>/weather-india</url-pattern>
</servlet-mapping>

<!-- SMS Alert -->
<servlet>
    <servlet-name>SmsAlertServlet</servlet-name>
    <servlet-class>com.smartkisan.servlets.SmsAlertServlet</servlet-class>
</servlet>

<servlet-mapping>
    <servlet-name>SmsAlertServlet</servlet-name>
    <url-pattern>/send-sms</url-pattern>
</servlet-mapping>
    <servlet>

    <servlet-name>WeeklyWeatherServlet</servlet-name>
    <servlet-class>com.smartkisan.servlets.WeeklyWeatherServlet</servlet-class>
</servlet>

<servlet-mapping>
    <servlet-name>WeeklyWeatherServlet</servlet-name>
    <url-pattern>/weekly-weather</url-pattern>
</servlet-mapping>
<servlet>
  <servlet-name>CheckSchemesServlet</servlet-name>
  <servlet-class>com.smartkisan.servlets.CheckSchemesServlet</servlet-class>
</servlet>

<servlet-mapping>
  <servlet-name>CheckSchemesServlet</servlet-name>
  <url-pattern>/check-schemes</url-pattern>
</servlet-mapping>
<!-- Government Schemes Eligibility -->
<servlet>
    <servlet-name>SchemesEligibilityServlet</servlet-name>
    <servlet-class>com.smartkisan.servlets.SchemesEligibilityServlet</servlet-class>
</servlet>

<servlet-mapping>
    <servlet-name>SchemesEligibilityServlet</servlet-name>
    <url-pattern>/schemes-check</url-pattern>
</servlet-mapping>

    <!-- Welcome -->
    <welcome-file-list>
        <welcome-file>index.jsp</welcome-file>
    </welcome-file-list>

</web-app>